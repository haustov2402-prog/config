# GitHub Token для публикации результатов через Actions
# Получить токен: https://github.com/settings/tokens (нужен scope: repo)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Владелец репозитория (ваш ник на GitHub)
GITHUB_REPO_OWNER=your_username

# Название репозитория
GITHUB_REPO_NAME=russia-mobile-vpn-aggregator
